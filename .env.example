# ─── Transport ───────────────────────────────────────────────────────────────

# Which transport to use: stdio (default, for local MCP clients like Claude Code)
# or sse (HTTP server, for remote/hosted MCP access)
MCP_TRANSPORT=stdio

# ─── SSE / HTTP mode (only used when MCP_TRANSPORT=sse) ──────────────────────

# Port the HTTP server listens on
PORT=3000

# Bearer token to protect the SSE endpoints.
# If unset, the endpoints are unauthenticated.
# MCP_API_KEY=your-secret-token-here

# Requests per second allowed per client IP before returning 429.
MCP_RATE_LIMIT_RPS=10

# CORS — only applies in SSE mode.
# Leave unset (default) to disable CORS headers entirely (recommended for local/internal use).
# Set to * to allow requests from any browser origin (useful for testing or public deployments).
# Set to one or more comma-separated origins for a strict allowlist.
# CORS_ORIGIN=*
# CORS_ORIGIN=https://your-app.example.com,https://staging.example.com

# ─── SEMP client ─────────────────────────────────────────────────────────────

# Timeout in milliseconds for upstream SEMP HTTP calls
SEMP_TIMEOUT_MS=10000

# Controls the semp_request passthrough tool:
#   disabled     — tool is not registered at all
#   monitor_only — only GET requests to the monitor API are allowed
#   advanced     — full access to monitor, config, and action APIs (default)
SEMP_PASSTHROUGH_MODE=advanced

# Maximum bytes of a queue message payload shown in list_queue_messages previews
MESSAGE_PAYLOAD_PREVIEW_BYTES=2048

# ─── Logging ─────────────────────────────────────────────────────────────────

# Log level: error | warn | info | debug  (default: info)
# debug also writes a separate debug-DDMMYYYY.log file in logs/
LOG_LEVEL=info

# ─── Broker configuration (alternative to brokers.json) ──────────────────────
# Define brokers via environment variables. Each broker needs all four fields.
# Replace MY_BROKER with any unique identifier (uppercase recommended).
# Multiple brokers: repeat the block with different identifiers.
#
# SEMP_BROKER_MY_BROKER_URL=http://your-solace-host:8080
# SEMP_BROKER_MY_BROKER_USERNAME=admin
# SEMP_BROKER_MY_BROKER_PASSWORD=admin
# SEMP_BROKER_MY_BROKER_LABEL=My Broker
